# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.env
!.env.example

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
e2e/test-results/
e2e/playwright-report/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node / Frontend
node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# Data files (never commit AIS data)
data/
!data/README.md
*.csv
*.json.gz

# Production config overrides (never commit tuned thresholds or operator whitelists)
# Use config/*.local.yaml for instance-specific calibration — see config/README.md
config/*.local.yaml
config/local/

# Secrets
*.pem
*.key
secrets/

# Internal/private docs (dot-prefixed files in docs/)
docs/.*

# OS
.DS_Store
Thumbs.db

# Alembic generated (keep env.py and versions/)
backend/alembic/versions/*.py
!backend/alembic/versions/.gitkeep

# Worktrees (if using git worktrees)
.worktrees/
.claude/
.mcp.json
backend/radiancefleet.db
backend/radiancefleet.db*
radiancefleet.db
.playwright-mcp/

# Screenshots and internal docs (opsec)
railway-web-check.png
*.screenshot.png
meeting*/
notes/
internal/
