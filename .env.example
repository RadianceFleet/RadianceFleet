# Database (SQLite — no Docker needed)
DATABASE_URL=sqlite:///radiancefleet.db
# For PostgreSQL (optional, requires Docker): DATABASE_URL=postgresql+psycopg2://radiancefleet:radiancefleet@localhost:5432/radiancefleet

# Config file paths (relative to backend/ directory)
# Defaults point to tracked files with baseline values.
# For production, use *.local.yaml overrides (gitignored) — see config/README.md
CORRIDORS_CONFIG=../config/corridors.yaml
RISK_SCORING_CONFIG=../config/risk_scoring.yaml
# CORRIDORS_CONFIG=../config/corridors.local.yaml
# RISK_SCORING_CONFIG=../config/risk_scoring.local.yaml

# Logging
LOG_LEVEL=INFO

# Gap detection thresholds
GAP_MIN_HOURS=2.0
GAP_ALERT_HOURS=6.0

# STS detection
STS_PROXIMITY_METERS=200.0
STS_MIN_WINDOWS=8

# Optional: Commercial satellite API keys (never commit real values)
# CAPELLA_API_KEY=
# PLANET_API_KEY=
# UMBRA_API_KEY=

# Data fetcher
# DATA_DIR=data
# DATA_FETCH_TIMEOUT=120.0

# Required: aisstream.io — Real-time AIS via WebSocket (free, requires sign-up)
# Get your API key at: https://aisstream.io/
AISSTREAM_API_KEY=your_key_here

# Required: Global Fishing Watch — Vessel events + SAR detections (free non-commercial)
# Get your token at: https://globalfishingwatch.org/our-apis/
GFW_API_TOKEN=your_token_here

# Required: Copernicus CDSE — Sentinel-1 SAR catalog (free, requires registration)
# Register at: https://dataspace.copernicus.eu/
COPERNICUS_CLIENT_ID=your_client_id
COPERNICUS_CLIENT_SECRET=your_client_secret

# Optional: AISHub — Batch AIS positions (requires contributing your own AIS receiver)
# Join at: https://www.aishub.net/
# AISHUB_USERNAME=your_username

# Norwegian AIS (Kystverket)
KYSTVERKET_ENABLED=false
KYSTVERKET_HOST=153.44.253.27
KYSTVERKET_PORT=5631

# Finnish AIS (Digitraffic)
DIGITRAFFIC_ENABLED=false

# CREA Russia Fossil Tracker
CREA_ENABLED=false
CREA_API_BASE_URL=https://api.russiafossiltracker.com

# Paid verification providers (Phase D stubs)
SKYLIGHT_API_KEY=
SPIRE_API_KEY=
SEAWEB_API_KEY=
VERIFICATION_MONTHLY_BUDGET_USD=500

# ── Equasis metadata enrichment (opt-in) ──────────────────────────────────────
# WARNING: Equasis ToS explicitly prohibits automated scraping.
# This is DISABLED by default. Enable only for dev/research use.
# For production metadata enrichment, use Datalastic API instead.
# See https://www.equasis.org/EquasisWeb/public/ToU for full ToS.
EQUASIS_SCRAPING_ENABLED=false
# EQUASIS_USERNAME=your_email@example.com
# EQUASIS_PASSWORD=your_password

# ── Scoring overrides (for platforms without filesystem access, e.g. Render) ──
# Patch specific scoring thresholds without replacing the full YAML config.
# Format: JSON object with section keys matching risk_scoring.yaml structure.
# SCORING_OVERRIDES={"gap_duration":{"24h_plus":60},"corridor":{"sts_zone":2.0}}

# Extra MMSI whitelist entries (comma-separated, merged with legitimate_operators.yaml)
# EXTRA_WHITELISTED_MMSIS=219010207,224006160,265609960

# ── Watchlist stub scoring ─────────────────────────────────────────────────────
# Score sanctioned vessels with no AIS history based on watchlist signals.
WATCHLIST_STUB_SCORING_ENABLED=true

# ── Stage 4-5 detectors (enabled by default — set =false to disable) ──────────
# MERGE_CHAIN_DETECTION_ENABLED=false
# MERGE_CHAIN_SCORING_ENABLED=false
# FINGERPRINT_ENABLED=false
# FINGERPRINT_SCORING_ENABLED=false
# SAR_CORRELATION_ENABLED=false
# SAR_CORRELATION_SCORING_ENABLED=false
# OWNERSHIP_GRAPH_ENABLED=false
# OWNERSHIP_GRAPH_SCORING_ENABLED=false
# CONVOY_DETECTION_ENABLED=false
# CONVOY_SCORING_ENABLED=false
# VOYAGE_PREDICTION_ENABLED=false
# VOYAGE_SCORING_ENABLED=false
# CARGO_INFERENCE_ENABLED=false
# WEATHER_CORRELATION_ENABLED=false

# ── Public Platform Deployment ──────────────────────────────────────────────
# IMPORTANT: Do NOT set RADIANCEFLEET_API_KEY on the public instance.
# Setting it blocks ALL GET requests (including /api/v1/vessels, /api/v1/alerts).
# The JWT admin auth below replaces it for write operations only.
# RADIANCEFLEET_API_KEY=   ← leave this commented/unset on public instance

# Admin JWT authentication (replaces RADIANCEFLEET_API_KEY for write-only protection)
# Generate secret with: openssl rand -hex 32
ADMIN_JWT_SECRET=your_256bit_random_secret_here
ADMIN_PASSWORD=your_strong_admin_password_here

# Email notifications via Resend API (register at resend.com, free tier available)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM_DOMAIN=radiancefleet.com

# SMTP fallback email (used only if RESEND_API_KEY is not set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password

# Public URL (used in email confirmation links and OG meta tags)
PUBLIC_URL=https://radiancefleet.com

# CORS origins for public instance (comma-separated — add your Cloudflare Pages domain)
CORS_ORIGINS=https://radiancefleet.pages.dev,https://radiancefleet.com

# ── Sentry Error Tracking (optional — install with `uv pip install 'radiancefleet[monitoring]'`) ──
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production
